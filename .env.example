# Transport configuration
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Pantry API upstream (mock by default in dev)
PANTRY_DEV_MODE=true
PANTRY_API__BASE_URL=http://localhost:8001

# Auth (DEMO ONLY — replace with OAuth 2.1 / IdP for production deployment)
PANTRY_AUTH__DEMO_TOKEN_READONLY=demo-readonly
PANTRY_AUTH__DEMO_TOKEN_READWRITE=demo-readwrite

# OpenTelemetry
OTEL_SERVICE_NAME=claude-mcp-server-template
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Logging
LOG_LEVEL=INFO
