# FastAPI mock for the demo stack. Standalone, minimal deps.

FROM python:3.14-slim

WORKDIR /app

# Pin versions matching pyproject.toml lower-bound declarations
RUN pip install --no-cache-dir \
      "fastapi==0.115.0" \
      "uvicorn[standard]==0.32.0" \
      "httpx==0.28.1"

COPY pantry_mock_api.py ./

ENV PYTHONUNBUFFERED=1

EXPOSE 8001

# Non-root user (security hardening)
RUN useradd --create-home --shell /bin/bash --uid 1001 pantry \
    && chown -R pantry:pantry /app
USER pantry

HEALTHCHECK --interval=15s --timeout=5s --start-period=5s --retries=3 \
  CMD python -c "import httpx, sys; sys.exit(0 if httpx.get('http://localhost:8001/', timeout=3.0).is_success else 1)"

CMD ["uvicorn", "pantry_mock_api:app", "--host", "0.0.0.0", "--port", "8001"]
